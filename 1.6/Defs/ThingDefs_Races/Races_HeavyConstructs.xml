			<li>VR_Construct_SteamHammer_Heavy</li>
			<li>VR_Construct_StakeDriver_Heavy</li>
		</weaponTags>
		<techHediffsChance>1</techHediffsChance>
		<techHediffsMoney>9999~9999</techHediffsMoney>
	</PawnKindDef>

