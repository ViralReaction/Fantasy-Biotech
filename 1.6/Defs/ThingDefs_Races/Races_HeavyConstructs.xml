	<ThingDef ParentName="VR_HeavyConstruct">
		<defName>VR_Construct_Delver</defName>
		<label>delver</label>
		<description>A heavy construct built for mining in treacherous locations. While intended for excavation, the delver's gigantic drill and ultra-thick armor makes it a dangerous force in combat.</description>
		<statBases>
			<MoveSpeed>1.9</MoveSpeed>
			<ArmorRating_Blunt>0.40</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.80</ArmorRating_Sharp>
			<BandwidthCost>3</BandwidthCost>
			<WorkSpeedGlobal>1.5</WorkSpeedGlobal>
		</statBases>
		<race>
			<body>VR_Construct_Tunneler</body>
			<baseBodySize>3.5</baseBodySize>
			<baseHealthScale>1.5</baseHealthScale>
			<lifeStageAges>
				<li>
					<def>MechanoidFullyFormed</def>
					<minAge>0</minAge>
					<soundWounded>Pawn_Mech_Tunneler_Wounded</soundWounded>
					<soundDeath>Pawn_Mech_Tunneler_Death</soundDeath>
					<soundCall>Pawn_Mech_Tunneler_Call</soundCall>
				</li>
			</lifeStageAges>
			<bulletStaggerEffecterDef>TunnelerSlowedDown</bulletStaggerEffecterDef>
			<mechEnabledWorkTypes>
				<li>Mining</li>
			</mechEnabledWorkTypes>
			<detritusLeavings>
				<li>
					<def>VR_ChunkConstructSlag</def>
					<texOverrideIndex>0</texOverrideIndex>
					<spawnChance>0.5</spawnChance>
				</li>
				<li>
					<def>VR_ChunkConstructSlag</def>
					<texOverrideIndex>3</texOverrideIndex>
					<spawnChance>0.5</spawnChance>
				</li>
				<li>
					<def>VR_ChunkConstructSlag</def>
					<texOverrideIndex>1</texOverrideIndex>
					<spawnChance>0.5</spawnChance>
				</li>
			</detritusLeavings>
		</race>
		<tools>
			<li>
				<label>drill</label>
				<capacities>
					<li>Demolish</li>
				</capacities>
				<power>50</power>
				<armorPenetration>0.60</armorPenetration>
				<cooldownTime>4.5</cooldownTime>
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
			</li>
		</tools>
	</ThingDef>
  
