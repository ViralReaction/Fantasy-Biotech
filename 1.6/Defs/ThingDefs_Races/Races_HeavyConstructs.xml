					<drawSize>2.5</drawSize>
					<shadowData>
						<volume>(0.4, 0.8, 0.4)</volume>
					</shadowData>
				</bodyGraphicData>
			</li>
		</lifeStages>
		<defendPointRadius>0</defendPointRadius>
		<weaponTags>
