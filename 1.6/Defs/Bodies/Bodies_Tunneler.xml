						</li>
						<li>
							<def>SmellSensor</def>
							<coverage>0.02</coverage>
						</li>
						<!-- The big drill -->
						<li>
							<def>VR_Construct_Tunneler_Drill</def>
							<customLabel>siege drill</customLabel>
							<coverage>0.75</coverage>
							<height>Middle</height>
							<groups>
								<li>HeadAttackTool</li>
							</groups>
						</li>
