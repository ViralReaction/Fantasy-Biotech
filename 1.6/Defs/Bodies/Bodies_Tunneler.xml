							<def>VR_BrassOcular</def>
							<customLabel>left sight sensor</customLabel>
							<coverage>0.05</coverage>
						</li>
						<li>
							<def>VR_BrassOcular</def>
							<customLabel>right sight sensor</customLabel>
							<coverage>0.05</coverage>
						</li>
						<li>
