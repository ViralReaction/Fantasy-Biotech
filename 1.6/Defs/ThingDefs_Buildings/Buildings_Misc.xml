<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<ThingDef ParentName="BuildingBase">
		<defName>VR_Construct_Lift</defName>
		<label>great steam lift</label>
		<description>A steam-powered lift used by forges to deliver constructs into battle.</description>
		<thingClass>Building</thingClass>
		<drawerType>MapMeshAndRealTime</drawerType>
		<graphicData>
			<texPath>Things/Building/Misc/SteamConstructLift</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(4, 4)</drawSize>
		</graphicData>
		<receivesSignals>true</receivesSignals>
		<drawHighlight>true</drawHighlight>
		<drawHighlightOnlyForHostile>true</drawHighlightOnlyForHostile>
		<altitudeLayer>Building</altitudeLayer>
		<stealable>false</stealable>
		<rotatable>true</rotatable>
		<size>(4,4)</size>
		<statBases>
			<MaxHitPoints>2500</MaxHitPoints>
			<Flammability>0</Flammability>
			<Mass>10000</Mass>
			<Beauty>-1000</Beauty>
		</statBases>
		<damageMultipliers>
			<li>
				<damageDef>Flame</damageDef>
				<multiplier>0</multiplier>
			</li>
		</damageMultipliers>
		<tickerType>Normal</tickerType>
		<comps>
			<li Class="FantasyBiotech.CompProperties_SteamSpray"/>
			<li Class="CompProperties_SendSignalOnCountdown">
				<signalTag>CompCanBeDormant.WakeUp</signalTag>
				<countdownCurveTicks>
					<points>
						<li>(599, 0)</li>
						<li>(600, 1)</li>
						<li>(600000, 0.1)</li>
						<li>(1200000, 0)</li>
					</points>
				</countdownCurveTicks>
			</li>
			<li Class="CompProperties_WakeUpDormant">
				<wakeUpSound>MechanoidsWakeUp</wakeUpSound>
			</li>
			<li Class="CompProperties_FleckEmitter">
				<fleck>ActivatorCountdownFlash</fleck>
				<emissionInterval>100</emissionInterval>
				<soundOnEmission>ActivatorCountdown_Ambience</soundOnEmission>
				<saveKeysPrefix>flash</saveKeysPrefix>
			</li>
			<li Class="CompProperties_MoteEmitter">
				<mote>Mote_ActivatorCountdownGlow</mote>
				<maintain>True</maintain>
				<saveKeysPrefix>glow</saveKeysPrefix>
			</li>
		</comps>
		<passability>PassThroughOnly</passability>
		<pathCost>50</pathCost>
		<fillPercent>0.5</fillPercent>
		<hasTooltip>true</hasTooltip>
		<building>
			<deconstructible>false</deconstructible>
			<claimable>false</claimable>
		</building>
		<killedLeavings>
			<VR_ChunkConstructSlag>1</VR_ChunkConstructSlag>
		</killedLeavings>
		<terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
		<uiIconScale>0.95</uiIconScale>
	</ThingDef>

	<ThingDef ParentName="ChunkSlagSteel">
		<defName>VR_ChunkConstructSlag</defName>
		<label>construct slag chunk</label>
		<description>The remains of a smashed construct. While useless in its current form, it can be smelted to recover steel.</description>
		<graphicData>
			<texPath>Things/Building/Ruins/ConstructDetritus</texPath>
			<graphicClass>Graphic_Random</graphicClass>
		</graphicData>
		<saveCompressible>false</saveCompressible>
	</ThingDef>

</Defs>